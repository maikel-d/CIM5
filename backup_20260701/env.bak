# ============================================
#   Variables de Entorno - Sistema de Gestión
#   Dirección General
# ============================================
#
# Copia este archivo como .env y modifica los valores:
#   cp .env.example .env
#
# Luego inicia los contenedores:
#   docker compose up -d
#
# ============================================

# --- Seguridad ---
# Genera una clave única con: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=KcEcg8D1LFliRo3gg2_QggXlJlQ5keDIeXZOeR76uuoD5vJokmqH1zMU06RkYRSMcyg

# --- Modo depuración (False en producción) ---
DEBUG=False

# --- Hosts permitidos (separados por coma) ---
# Incluye la IP del servidor para acceso por red local
ALLOWED_HOSTS=192.168.0.101,localhost,127.0.0.1,cimcinco.com,www.cimcinco.com

# --- Base de Datos (PostgreSQL) ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=direccion
DB_USER=direccion
DB_PASSWORD=PTwzrXqYtm2OJSDQ-h8oxhyQWpw
DB_HOST=db
DB_PORT=5432

# --- Puerto de la interfaz web ---
WEBUI_PORT=8080
WEBUI_PORT_SSL=8443

# --- Dominio (dejar vacío si solo accedes por IP) ---
DOMAIN=cimcinco.com
SECURE_SSL_REDIRECT=True
# CERTBOT_EMAIL=admin@midominio.gob.ve

# --- Credenciales del superusuario por defecto ---
# (Solo se usa la primera vez que se inicia el contenedor)
ADMIN_PASSWORD=XApzEzS7qH8jeakhXNYdLg1gySM

# --- Backup automático (backup_db.sh) ---
# Directorio donde se guardan los backups (por defecto: ./backups)
# BACKUP_DIR=/ruta/personalizada/backups

# Días de retención de backups (por defecto: 30)
# BACKUP_RETENTION_DAYS=30
SECURE_COOKIES=true

# Redis
REDIS_URL=redis://redis:6379/1
