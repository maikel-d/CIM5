# ============================================
#   Configuracion de Entorno - Direccion General
#   Copia este archivo como .env y ajusta los valores
# ============================================

# --- Seguridad ---
# Genera una clave unica con: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=cambiar-esta-clave-en-produccion

# Modo debug: NO activar en produccion
# DEBUG=True
DEBUG=False

# Hosts permitidos (separados por coma)
ALLOWED_HOSTS=127.0.0.1,localhost,192.168.0.101

# Dominio publico (para HSTS y cookies seguras)
# DOMAIN=cimcinco.commidominio.com
# DOMAIN=cimcinco.com

# --- Base de Datos ---
# Produccion: PostgreSQL (recomendado)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=direccion
DB_USER=direccion
DB_PASSWORD=direccion
DB_HOST=db
DB_PORT=5432

# Desarrollo local: SQLite (descomentar para usar)
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=data/db.sqlite3
# DB_USER=
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=

# --- Redis (Cache) ---
# En Docker: redis://redis:6379/1
# En local: redis://127.0.0.1:6379/1
REDIS_URL=redis://redis:6379/1

# --- Puertos Web ---
WEBUI_PORT=8080
WEBUI_PORT_SSL=8443  # Puerto HTTPS (solo si SECURE_SSL_REDIRECT=True)

# --- SSL / HTTPS ---
# Redirigir HTTP a HTTPS
SECURE_SSL_REDIRECT=False

# Cookies seguras (requiere HTTPS). Activar solo si tienes SSL configurado.
# SECURE_COOKIES=true
SECURE_COOKIES=false

# --- Admin ---
# !! CAMBIA ESTA CONTRASENA EN PRODUCCION !!
ADMIN_PASSWORD=admin321
