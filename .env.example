# ============================================
#   Variables de Entorno - Sistema de Gestion
#   Direccion General
# ============================================
#
# Copia este archivo como .env y modifica los valores:
#   cp .env.example .env
#
# ============================================
#   MODO DESARROLLO LOCAL
# ============================================
# Para trabajar en tu PC con SQLite:
#
#   DEBUG=True
#   SECURE_SSL_REDIRECT=False
#   DB_ENGINE=django.db.backends.sqlite3
#   DOMAIN=
#
# Luego inicia el servidor:
#   python manage.py runserver 0.0.0.0:8000
#
# ============================================
#   MODO PRODUCCION (Docker + PostgreSQL)
# ============================================
# Para desplegar en servidor:
#
#   DEBUG=False
#   SECURE_SSL_REDIRECT=True
#   DB_ENGINE=django.db.backends.postgresql
#   DOMAIN=midominio.gob.ve
#
# Luego inicia los contenedores:
#   docker compose up -d
#
# ============================================

# --- Seguridad ---
SECRET_KEY=cambiar-esta-clave-en-produccion

# --- Modo depuracion ---
# True en desarrollo local, False en produccion
DEBUG=False

# --- Hosts permitidos (separados por coma) ---
# Local: 127.0.0.1,localhost | Produccion: IP_del_servidor
ALLOWED_HOSTS=127.0.0.1,localhost

# --- Base de Datos ---
# Local: DB_ENGINE=django.db.backends.sqlite3 / DB_NAME=data/db.sqlite3
# Produccion: DB_ENGINE=django.db.backends.postgresql / DB_NAME=direccion / ...
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=data/db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# --- Puerto web ---
# Local: 8000 | Produccion: 80
WEBUI_PORT=8000

# --- Puerto HTTPS (solo produccion) ---
# WEBUI_PORT_SSL=8443

# --- Dominio ---
# Local: DOMAIN= (vacio) | Produccion: DOMAIN=midominio.gob.ve
DOMAIN=

# --- SSL Redirect ---
# Local: False | Produccion: True
SECURE_SSL_REDIRECT=False

# --- Superusuario por defecto ---
ADMIN_PASSWORD=admin321

# --- Certbot (solo produccion) ---
# CERTBOT_EMAIL=admin@midominio.gob.ve

# --- Backup ---
# BACKUP_DIR=backups
# BACKUP_RETENTION_DAYS=30

# --- Gunicorn (solo produccion) ---
# GUNICORN_WORKERS=4
# GUNICORN_TIMEOUT=120
# GUNICORN_LOG_LEVEL=info
